---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Inter:wght@300;400;600;700&family=Jomolhari&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	:root {
		--font-family-sans: 'Inter', sans-serif;
        --font-family-heading: 'Montserrat', sans-serif;
		--font-family-script: 'Great Vibes', cursive;
        --font-family-arya: 'Ephesis', cursive;
        --font-family-serif: 'Inria Serif', serif;
		
        --color-bg-primary: #000000;
        --color-bg-secondary: #0a0a0a;
        --color-text-primary: #ffffff;
        --color-text-secondary: #cccccc;
        --color-accent: #b19cd9; /* Light purple accent based on images */
        --color-accent: #b19cd9; /* Light purple accent based on images */
	}

    @font-face {
        font-family: 'Ephesis';
        src: url('/fonts/Ephesis-Regular.ttf') format('truetype');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
    }

    @font-face {
        font-family: 'Inria Serif';
        src: url('/fonts/InriaSerif-Light.ttf') format('truetype');
        font-weight: 300;
        font-style: normal;
        font-display: swap;
    }

    @font-face {
        font-family: 'Inria Serif';
        src: url('/fonts/InriaSerif-Regular.ttf') format('truetype');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
    }

    @font-face {
        font-family: 'Inria Serif';
        src: url('/fonts/InriaSerif-Italic.ttf') format('truetype');
        font-weight: 400;
        font-style: italic;
        font-display: swap;
    }

    @font-face {
        font-family: 'Inria Serif';
        src: url('/fonts/InriaSerif-Bold.ttf') format('truetype');
        font-weight: 700;
        font-style: normal;
        font-display: swap;
    }

	html {
		font-family: var(--font-family-sans);
		background: var(--color-bg-primary);
        color: var(--color-text-primary);
        scroll-behavior: smooth;
	}

    body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
    }

    h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-family-heading);
        margin: 0;
    }

    a {
        color: inherit;
        text-decoration: none;
    }

    button {
        font-family: inherit;
    }
</style>
