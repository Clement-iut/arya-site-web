---
---
<section class="hero">
    <div class="hero-bg"></div>
    <div class="content">
        <span class="subtitle">Compagnie de danse</span>
        <h1 class="title">Arya</h1>
        <p class="tagline">L'art de s'exprimer en mouvement</p>
        <a href="#about" class="cta-button">Découvrir la compagnie &rarr;</a>
    </div>
</section>

<style>
    .hero {
        position: relative;
        height: 100vh;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
    }

    .hero-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('/images/hero-bg.jpg');
        background-size: cover;
        background-position: center;
        filter: brightness(0.6);
        z-index: 1;
    }

    .content {
        position: relative;
        z-index: 2;
        text-align: center;
        color: white;
        padding: 0 1rem;
        animation: fadeIn 1.5s ease-out;
    }

    .subtitle {
        font-family: var(--font-family-serif);
        font-size: 1.2rem;
        letter-spacing: 2px;
        text-transform: none;
        display: block;
        margin-bottom: 1rem;
        opacity: 0.9;
    }

    .title {
        font-family: var(--font-family-arya);
        font-size: 8rem;
        font-weight: 400;
        line-height: 1.2;
        margin: 0;
        background: linear-gradient(135deg, #fff 0%, #e0e0e0 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }

    .tagline {
        font-family: var(--font-family-serif);
        font-size: 1.5rem;
        margin-top: 2rem;
        margin-bottom: 3rem;
        font-weight: 300;
        opacity: 0.9;
    }

    .cta-button {
        display: inline-block;
        padding: 0.8rem 2rem;
        background-color: rgba(255, 255, 255, 0.7);
        color: #000;
        font-family: var(--font-family-serif);
        font-weight: 600;
        border-radius: 12px;
        border: 2px solid rgba(0, 0, 0, 0.15); /* Stroke 15% black, weight 2 */
        transition: all 0.3s ease;
        backdrop-filter: blur(5px);
    }

    .cta-button:hover {
        background-color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 768px) {
        .title {
            font-size: 5rem;
        }
        
        .tagline {
            font-size: 1.1rem;
        }

        .subtitle {
            font-size: 1rem;
        }
    }
</style>
