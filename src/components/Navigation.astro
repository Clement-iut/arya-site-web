---
<nav id="navbar">
    <div class="nav-content">
        <a href="/" class="nav-link">Accueil</a>
        <a href="/artistes" class="nav-link">Artistes</a>
        <a href="/" class="logo-container">
            <img src="/images/arya-logo.png" alt="Arya Logo" class="logo" />
        </a>
        <a href="/spectacles" class="nav-link">Spectacles</a>
        <a href="/contact" class="nav-link">Contact</a>
    </div>
</nav>

<script>
    const navbar = document.getElementById('navbar');
    
    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
            navbar?.classList.add('scrolled');
        } else {
            navbar?.classList.remove('scrolled');
        }
    });
</script>

<style>
    nav {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1000;
        padding: 1rem 0;
        transition: background-color 0.3s ease, padding 0.3s ease;
    }

    nav.scrolled {
        background-color: rgba(0, 0, 0, 0.9);
        padding: 0.5rem 0;
        backdrop-filter: blur(5px);
    }

    .nav-content {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 2rem;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .nav-link {
        font-family: var(--font-family-sans);
        color: #ffffff;
        font-weight: 500;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 1px;
        transition: color 0.3s ease;
    }

    .nav-link:hover {
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.2);
    }

    /* Distributed gradient colors across the 4 links on HOVER */
    
    /* 1. Accueil - Start of gradient (Cyan) */
    .nav-link:nth-of-type(1):hover {
        color: #5CE0D8;
    }

    /* 2. Artistes - Mid-left (Cyan-Blue mix) */
    .nav-link:nth-of-type(2):hover {
        color: #79C3DE;
    }

    /* 4. Spectacles - Mid-right (Blue-Purple mix) */
    .nav-link:nth-of-type(4):hover {
        color: #96A5E5; 
    }

    /* 5. Contact - End of gradient (Purple) */
    .nav-link:nth-of-type(5):hover {
        color: #B388EB; 
    }

    .logo-container {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        overflow: hidden;
        transition: transform 0.3s ease;
    }

    .logo-container:hover {
        transform: scale(1.1);
    }

    .logo {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    @media (max-width: 768px) {
        .nav-content {
            gap: 1rem;
            flex-wrap: wrap;
        }
        
        .logo-container {
            order: -1;
            width: 50px;
            height: 50px;
        }

        .nav-link {
            font-size: 0.8rem;
        }
    }
</style>
