---

<Layout title="Nos Spectacles - Arya">
	<Navigation />
	<main>
        <h1 class="page-title">Nos événements</h1>

        <section class="spectacles-list">
            {spectacles.map((spectacle, index) => (
                <div class={`spectacle-row ${index % 2 !== 0 ? 'reversed' : ''}`}>
                    <div class="content-col">
                        <h2 class="spectacle-title">{spectacle.title}</h2>
                        <p class="spectacle-desc">{spectacle.description}</p>
                        {spectacle.date && <p class="spectacle-date">{spectacle.date}</p>}
                        {spectacle.gallery ? (
                            <button 
                                class="btn-action btn-gallery" 
                                data-title={spectacle.title}
                                data-images={JSON.stringify(spectacle.gallery)}
                            >
                                {spectacle.btnText}
                            </button>
                        ) : (
                            <a href={spectacle.link} 
                               class="btn-action"
                               onclick={spectacle.link === "#" ? "event.preventDefault(); alert('Bientôt disponible');" : ""}
                            >
                                {spectacle.btnText}
                            </a>
                        )}
                    </div>
                    <div class="image-col">
                        <img src={spectacle.image} alt={spectacle.title} />
                    </div>
                </div>
            ))}
        </section>

        <ModalGallery />

        <section class="posing-section">
            <h2 class="posing-title">Prestations</h2>
            
            <div class="posing-list">
                {posingEvents.map(event => (
                    <div class="posing-item">
                        <span class="year">{event.year}</span>
                        <div class="details">
                            <h3 class="event-title">{event.title}</h3>
                            <p class="event-desc">{event.description}</p>
                        </div>
                    </div>
                ))}
            </div>
        </section>
	</main>
    <Footer />
</Layout>

<style>
    main {
        background-color: #000;
        min-height: 100vh;
        padding-top: 100px;
        padding-bottom: 4rem;
    }

    .page-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 4rem;
        font-weight: 700;
        color: #fff;
        text-align: center;
        margin-bottom: 6rem;
    }

    /* Spectacles List (Alternating) */
    .spectacles-list {
        display: flex;
        flex-direction: column;
        gap: 8rem;
        max-width: 1200px;
        margin: 0 auto 8rem;
        padding: 0 1rem;
    }

    .spectacle-row {
        display: flex;
        align-items: center;
        gap: 4rem;
    }

    .spectacle-row.reversed {
        flex-direction: row-reverse;
    }

    .content-col {
        flex: 1;
        color: #fff;
    }

    .image-col {
        /* Set fixed width container for alignment */
        flex: 0 0 544px;
        display: flex;
        justify-content: center;
    }

    .image-col img {
        width: 544px;
        height: 432px;
        object-fit: cover;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .spectacle-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
    }

    .spectacle-desc {
        font-family: 'Inter', sans-serif;
        font-size: 1.1rem;
        color: #ccc;
        margin-bottom: 1rem;
        line-height: 1.6;
    }

    .spectacle-date {
        font-family: 'Inter', sans-serif;
        color: #888;
        margin-bottom: 2rem;
    }

    .btn-action {
        display: inline-block;
        padding: 0.8rem 1.5rem;
        background-color: #fff;
        color: #000;
        font-family: 'Inter', sans-serif;
        font-weight: 600;
        font-size: 1rem;
        border: none;
        cursor: pointer;
        border-radius: 8px;
        margin-top: 1rem;
        text-decoration: none;
        transition: transform 0.2s, background-color 0.2s, background-image 0.2s, color 0.2s, box-shadow 0.2s;
    }

    .btn-action:hover {
        background-image: linear-gradient(to right, #5CE0D8, #B388EB);
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(179, 136, 235, 0.4);
    }

    /* Posing Section */
    .posing-section {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .posing-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 2rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 3rem;
    }

    .posing-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .posing-item {
        display: flex;
        gap: 4rem;
        padding: 1.5rem;
        border-radius: 12px;
        transition: background 0.3s ease;
    }

    .posing-item:hover {
        /* Subtle gradient on hover as requested */
        background: linear-gradient(to right, rgba(92, 224, 216, 0.1), rgba(179, 136, 235, 0.1));
    }

    .year {
        font-family: 'Inter', sans-serif;
        font-size: 1.2rem;
        color: #888;
        min-width: 80px;
    }

    .details {
        flex: 1;
    }

    .event-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.3rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 0.5rem;
    }

    .event-desc {
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        color: #aaa;
    }

    @media (max-width: 768px) {
        .image-col, .image-col img {
            flex: 1; /* Reset flex basis */
            width: 100%; /* Full width on mobile */
            height: auto; /* Maintain aspect ratio or set specific mobile height if needed */
            max-width: 544px; /* But don't exceed original size */
        }

        .page-title {
            font-size: 3rem;
            margin-bottom: 4rem;
        }

        .posing-item {
            flex-direction: column;
            gap: 0.5rem;
        }

        .year {
            font-size: 1rem;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('gallery-modal');
        const closeBtn = modal?.querySelector('.close-btn');
        const galleryTitle = document.getElementById('gallery-title');
        const galleryGrid = document.getElementById('gallery-grid');
        const galleryButtons = document.querySelectorAll('.btn-gallery');

        // Open modal
        galleryButtons.forEach(button => {
            button.addEventListener('click', () => {
                if (!modal || !galleryTitle || !galleryGrid) return;
                
                // Get data from button
                const title = button.getAttribute('data-title');
                try {
                    const rawData = button.getAttribute('data-images') || '[]';
                    console.log('Raw data-images attribute:', rawData);
                    const images = JSON.parse(rawData);
                    
                    // Set title
                    galleryTitle.textContent = title ? `Galerie : ${title}` : 'Galerie';
                    
                    // Clear previous images
                    galleryGrid.innerHTML = '';
                    
                    // Add new images
                    if (images.length === 0) {
                        galleryGrid.innerHTML = '<p style="grid-column: 1 / -1; text-align: center; color: #888; padding: 2rem;">Bientôt disponible...</p>';
                    } else {
                        images.forEach((item: any) => {
                            // Support strings (old format) or objects (new format)
                            const isString = typeof item === 'string';
                            const type = isString ? 'image' : (item.type || 'image');
                            const src = isString ? item : item.src;

                            const container = document.createElement('div');
                            container.className = 'gallery-image-container';
                            
                            if (type === 'video') {
                                const video = document.createElement('video');
                                video.src = src;
                                video.className = 'gallery-video';
                                video.controls = true;
                                container.appendChild(video);
                            } else {
                                const img = document.createElement('img');
                                img.src = src;
                                img.className = 'gallery-image';
                                img.alt = `Image de la galerie ${title || ''}`;
                                img.style.cursor = 'pointer'; // Indiquer que c'est cliquable
                                
                                // Écouteur pour ouvrir la lightbox
                                img.addEventListener('click', () => {
                                    const lightboxModal = document.getElementById('lightbox-modal');
                                    const lightboxImg = document.getElementById('lightbox-img');
                                    if (lightboxModal && lightboxImg) {
                                        lightboxImg.src = src;
                                        lightboxModal.style.display = 'flex';
                                    }
                                });

                                // Add error handler for placeholder images
                                img.onerror = function() {
                                    // Provide a styled fallback if image not found
                                    container.innerHTML = '<div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:#222; color:#555; text-align:center; padding:1rem; font-family:Inter,sans-serif; flex-direction:column;"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:0.5rem;"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg><span>Photo<br>indisponible</span></div>';
                                };
                                container.appendChild(img);
                            }
                            
                            galleryGrid.appendChild(container);
                        });
                    }
                    
                    // Show modal
                    modal.style.display = 'block';
                    document.body.style.overflow = 'hidden'; // Prevent scrolling
                } catch (e) {
                    console.error("Error parsing gallery images", e);
                }
            });
        });

        // Close modal
        const closeModal = () => {
            if (modal) {
                modal.style.display = 'none';
                document.body.style.overflow = 'auto'; // Restore scrolling
            }
        };

        if (closeBtn) {
            closeBtn.addEventListener('click', closeModal);
        }

        // Close when clicking outside
        window.addEventListener('click', (event) => {
            if (event.target === modal) {
                closeModal();
            }
        });
        
        // Lightbox logic
        const lightboxModal = document.getElementById('lightbox-modal');
        const lightboxCloseBtn = document.querySelector('.lightbox-close');
        
        const closeLightbox = () => {
            if (lightboxModal) {
                lightboxModal.style.display = 'none';
            }
        };

        if (lightboxCloseBtn) {
            lightboxCloseBtn.addEventListener('click', closeLightbox);
        }

        // Close lightbox when clicking outside the larger image
        if (lightboxModal) {
            lightboxModal.addEventListener('click', (event) => {
                if (event.target === lightboxModal) {
                    closeLightbox();
                }
            });
        }

        // Close on Escape key (for both modals)
        window.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                if (lightboxModal && lightboxModal.style.display === 'flex') {
                    closeLightbox();
                } else if (modal && modal.style.display === 'block') {
                    closeModal();
                }
            }
        });
    });
</script>
