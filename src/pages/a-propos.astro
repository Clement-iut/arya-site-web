---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import HelloAssoWidget from '../components/HelloAssoWidget.astro';
---

<Layout title="A Propos - Arya">
	<Navigation />
	<main>
        <div class="header-content">
            <h1 class="page-title">A propos de nous</h1>
            <p class="subtitle">Pour en savoir un peu plus sur la compagnie Arya !</p>
        </div>

        <section class="hero-image-section">
            <div class="image-container">
                <img src="/images/IMG_8181.jpeg" alt="La Compagnie Arya" />
            </div>
        </section>

        <section class="passion-section">
            <h2 class="passion-title">
                Née d'une passion commune,<br>
                la compagnie Arya donne vie à vos rêves artistiques.
            </h2>
        </section>

        <section class="history-section">
            <div class="history-grid">
                <div class="history-col">
                    <h3 class="history-subtitle">D'un simple rêve ...</h3>
                    <p>
                        C'est l'histoire de deux jeunes femmes d'une vingtaine d'années qui se mirent à rêver de créer leur propre association. De pouvoir créer un espace de créativité sans jugement, ni contrainte, où tous les styles auraient leur place et où tout le monde pourrait s'exprimer à travers l'art. Une association qui permettrait à ceux qui le veulent de se produire et de pouvoir montrer de quoi ils sont capables. Ce rêve est alors devenu le rêve de leurs amis artistes.
                    </p>
                </div>
                <div class="history-col">
                    <h3 class="history-subtitle">...à la réalité</h3>
                    <p>
                        Ce rêve ambitieux a commencé le 28 août 2020, cependant la crise sanitaire a freiné l'avancée d'Arya. Notre association alors en plein lancement peine à trouver le financement dont elle a besoin, mais la compagnie ne perd pas espoir ! Début juillet, 4 de nos danseuses ouvrent le compteur des prestations en accompagnant une jeune chanteuse lors d'un concert à Saint-Quentin !
                    </p>
                </div>
            </div>
            
            <div class="donation-container">
                <HelloAssoWidget 
                    url="https://www.helloasso.com/associations/compagnie-arya/formulaires/5" 
                    btnText="Faire un don ❤️" 
                    btnClass="btn-donation"
                />
            </div>
        </section>

        <section class="location-section">
            <h2 class="section-title">La salle de nos spectacles</h2>
            <div class="map-container">
                <iframe 
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2602.857692948746!2d2.673843576359046!3d49.34440657933758!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47e62ac73d325747%3A0x6b4c6e91f185440!2s2%20Pl.%20Saint-Georges%2C%2060710%20Chevri%C3%A8res!5e0!3m2!1sfr!2sfr!4v1709650000000!5m2!1sfr!2sfr" 
                    width="100%" 
                    height="450" 
                    style="border:0;" 
                    allowfullscreen="" 
                    loading="lazy" 
                    referrerpolicy="no-referrer-when-downgrade">
                </iframe>
            </div>
        </section>
	</main>
    <Footer />
</Layout>

<style>
    main {
        background-color: #000;
        min-height: 100vh;
        padding-top: 100px;
        padding-bottom: 4rem;
        color: #fff;
    }

    .header-content {
        text-align: center;
        margin-bottom: 3rem;
        padding: 0 1rem;
    }

    .page-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 4rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 1rem;
    }

    .subtitle {
        font-family: 'Inter', sans-serif;
        font-size: 1.2rem;
        color: #888;
    }

    .hero-image-section {
        max-width: 1000px;
        margin: 0 auto 6rem;
        padding: 0 1rem;
    }

    .image-container img {
        width: 100%;
        border-radius: 20px;
        /* box-shadow: 0 0 30px rgba(179, 136, 235, 0.15); */
    }

    /* Passion Section */
    .passion-section {
        text-align: center;
        margin-bottom: 6rem;
        padding: 0 1rem;
    }

    .passion-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 2.5rem;
        font-weight: 700;
        line-height: 1.4;
    }

    /* History Section */
    .history-section {
        max-width: 1000px;
        margin: 0 auto 8rem;
        padding: 0 1rem;
    }

    .history-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
    }

    .history-col {
        background-color: #0a0a0a;
        padding: 2rem;
        border-radius: 12px;
        border: 2px solid #222; /* Ensuring 2px for gradient visibility */
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease, background-color 0.3s ease;
        background-origin: border-box;
        background-clip: padding-box, border-box;
    }

    .history-col:hover {
        transform: scale(1.02);
        box-shadow: 0 0 15px rgba(179, 136, 235, 0.1); /* Matching Formulaire shadow */
        border-color: transparent;
        background-image: linear-gradient(#0a0a0a, #0a0a0a), linear-gradient(to right, #5CE0D8, #B388EB);
    }

    .history-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: #fff;
    }

    .history-col p {
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        color: #ccc;
        line-height: 1.6;
        text-align: justify;
    }

    .donation-container {
        text-align: center;
        margin-top: 4rem;
    }

    /* We define the btn-donation style here to pass it to the HelloAssoWidget if it supports global classes.
       Wait, HelloAssoWidget has its own styling. Let's check HelloAssoWidget.astro
       The widget accepts btnClass prop and applies it. It also has its own scoped styles.
       But if it uses global classes, this should work. Actually it's better to verify HelloAssoWidget later if this doesn't apply.
       For now, let's update this block.
    */
    :global(.btn-donation) {
        display: inline-block;
        padding: 1rem 3rem;
        background-color: #fff;
        color: #000;
        font-family: 'Montserrat', sans-serif;
        font-weight: 700;
        font-size: 1.2rem;
        border-radius: 50px;
        text-decoration: none;
        transition: transform 0.3s ease, background-color 0.3s ease, background-image 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 0 20px rgba(255, 255, 255, 0.1);
    }

    :global(.btn-donation:hover) {
        transform: translateY(-5px);
        background-image: linear-gradient(to right, #5CE0D8, #B388EB);
        background-color: transparent; /* Override white bg */
        color: #fff;
        box-shadow: 0 10px 30px rgba(179, 136, 235, 0.4);
    }

    /* Location Section */
    .location-section {
        max-width: 1000px;
        margin: 0 auto;
        text-align: center;
        padding: 0 1rem;
    }

    .section-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 3rem; /* Match "La salle de nos..." style from screenshot if possible but 3rem is good */
        font-weight: 700;
        margin-bottom: 3rem;
        text-align: left; /* Screenshot seems left aligned? Or maybe centered title. Let's keep consistent. Actually screenshot shows "La salle de nos..." very big at bottom left? No it's bottom center. */
        text-align: center;
    }

    .map-container {
        border-radius: 20px;
        overflow: hidden;
        border: 2px solid #222;
    }

    @media (max-width: 768px) {
        .history-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .page-title {
            font-size: 3rem;
        }

        .passion-title {
            font-size: 1.8rem;
        }
    }
</style>
